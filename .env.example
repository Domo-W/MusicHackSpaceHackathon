# Copy to .env (gitignored) and fill in your real keys.
# Suno key looks like: sk_live_<64 hex chars>.  Anthropic key looks like: sk-ant-...
SUNO_API_KEY=your-suno-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional local runtime settings.
# SONGS_DIR defaults to ./data/songs and is gitignored.
SONGS_DIR=./data/songs
DEFAULT_BPM=120

# Optional — Supabase song persistence (durable across host redeploys).
# When set, songs save to a Storage bucket + `songs` table instead of local disk.
# Run supabase-setup.sql once, then fill these (service_role is a SECRET — never commit):
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_BUCKET=songs
